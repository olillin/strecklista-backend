{
  "include": [
    "src"
  ],
  "compilerOptions": {
    "target": "es2016",
    "lib": [
      "ES2024"
    ],
    "module": "es2022",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./out",
    "esModuleInterop": true,
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
