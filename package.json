{
  "name": "strecklista-backend",
  "version": "0.3.0",
  "description": "Backend for the \"strecklista\" developed by P.R.I.T.",
  "main": "bundle/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc && rollup --config rollup.config.mjs",
    "start": "node .",
    "startenv": "node --env-file=.env .",
    "up": "docker compose -f docker-compose.yaml up -d",
    "dev": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up -d --build --force-recreate",
    "rmdevdb": "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml down && docker volume rm strecklista-backend_dev-db-data",
    "cleandev": "npm run rmdevdb && npm run dev",
    "lint": "eslint",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olillin/strecklista-backend.git"
  },
  "author": "olillin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/olillin/strecklista-backend/issues"
  },
  "homepage": "https://github.com/olillin/strecklista-backend",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "gammait": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.18.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pg": "^8.16.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prisma": "^7.4.1",
    "rollup": "^4.59.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.24.1"
  }
}
